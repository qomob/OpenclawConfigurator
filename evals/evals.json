{
  "skill_name": "openclaw-configurator",
  "version": "1.0.2",
  "evals": [
    {
      "id": 0,
      "category": "basic",
      "prompt": "我想配置一个专门帮我写代码的助手。他应该很冷静，不废话，用 Emoji 🤖。我是个全栈开发。帮我生成所有的 OPENClaw 配置文件。",
      "files": [],
      "assertions": {
        "must_contain_all_files": ["BOOTSTRAP.md", "AGENTS.md", "SOUL.md", "IDENTITY.md", "USER.md", "TOOLS.md", "HEARTBEAT.md", "MEMORY.md"],
        "must_contain_keywords": ["🤖", "~/.openclaw/workspace/", "git"],
        "must_not_contain": [],
